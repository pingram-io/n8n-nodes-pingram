{
  "name": "n8n-nodes-pingram",
  "version": "0.2.4",
  "description": "n8n community node for Pingram - Send SMS and Email notifications",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "pingram",
    "notifications",
    "sms",
    "email"
  ],
  "license": "MIT",
  "homepage": "https://github.com/pingram-io/n8n-nodes-pingram",
  "author": {
    "name": "Pingram",
    "email": "hello@pingram.io",
    "url": "https://pingram.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pingram-io/n8n-nodes-pingram.git"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "dist/nodes/Pingram/Pingram.node.js",
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "format": "prettier nodes credentials --write",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test": "npm run lint && npm run build",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/PingramApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Pingram/Pingram.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.28.0",
    "eslint": "^9.29.0",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.3.2",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "overrides": {
    "lodash": "^4.18.0"
  }
}
